# ADB state files. All per-workspace state lives under .adb/ as of #186, so a
# single entry covers the event logs, counters, scheduler state, memory db, etc.
# The bare legacy names below are kept only for a workspace not yet migrated.
.adb/
.adb_terminal_state.json
.offline_queue.json
.context_changelog.md
.events.jsonl
.governance.jsonl
.task_counter
.session_counter
# Derived graph index — a rebuildable cache computed from entity frontmatter
# links (decision D6). Never a source of truth; regenerated by `adb graph
# rebuild`, so it is workspace state, not versioned artifact.
/graph/
testdata/
sessions/
.env
.env.*
!.env.example
!.env.sample
!.env.template
